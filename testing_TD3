#include <cstring>

#include "header/sensor.h"
#include "header/motors.h"
#include "header/encoder.h"
#include "header/buggy.h"
#include "header/PID.h"

#define BLE_TX_PIN PA_11
#define BLE_RX_PIN PA_12
Serial bt(BLE_TX_PIN, BLE_RX_PIN);

SensorArray sensorPCB(PC_0, PB_0, PC_1, PA_4, PA_0, PA_1);

Motor rightMotor(PA_15, PC_2, PA_14);
Motor leftMotor(PB_7, PC_3, PA_13);

WheelEncoder leftEncoder(PC_10, PC_12, NC, 10.0f, 256);
WheelEncoder rightEncoder(PC_8, PC_6, NC, 10.0f, 256);

Buggy buggy(&leftMotor, &rightMotor, &leftEncoder, &rightEncoder, PC_4);

PID linePID(0.25, 0.0f, 0.0f, -0.15f, 0.15f);
PID leftSpeedPID(7.0f, 0.0f, 0.0f, -1000.0f, 1000.0f);
PID rightSpeedPID(7.0f, 0.0f, 0.0f, -1000.0f, 1000.0f);

float baseSpeed = 0.2f;

const float LINE_DT  = 0.01f;
const float SPEED_DT = 0.001f;

static int  line_lost_count     = 0;
const  int  LINE_LOST_THRESHOLD = 3;
static int  line_weak_warn_skip = 0;

float targetLeft  = 0.0f;
float targetRight = 0.0f;

static float cachedLeft  = 0.0f;
static float cachedRight = 0.0f;

static bool  line_follow_active = false;
static bool  test_active        = false;
static bool  raw_print_active   = false;
static float lineTimer          = 0.0f;

// Declared here so dbg print can always access them
static float filtered_position  = 0.0f;
static float raw_position_last  = 0.0f;

static char   ble_line_buf[96];
static size_t ble_line_len = 0;

static void poll_ble_serial();

// ── BLE helpers ────────────────────────────────────────────────────────────────
// At 9600 baud, each byte ~1 ms on the wire — long TX blocks the main loop and the
// tiny UART RX FIFO can overflow if we don't poll while sending. Interleave RX polls.

static void ble_send_line(const char *msg)
{
    int n = 0;
    for (const char *p = msg; *p; ++p) {
        bt.putc(*p);
        if ((++n & 7) == 0) {
            poll_ble_serial();
        }
    }
    bt.putc('\r');
    bt.putc('\n');
    poll_ble_serial();
}

// ── Internal helpers ───────────────────────────────────────────────────────────

static void seed_line_targets_from_sensors()
{
    const float position   = sensorPCB.getPosition();
    const float correction = linePID.compute(position, LINE_DT);
    targetLeft  = baseSpeed + correction;
    targetRight = baseSpeed - correction;
}

static void stop_autonomous_no_spin()
{
    line_follow_active  = false;
    test_active         = false;
    line_lost_count     = 0;
    filtered_position   = 0.0f;
    raw_position_last   = 0.0f;
    buggy.stop();
    linePID.reset();
    leftSpeedPID.reset();
    rightSpeedPID.reset();
    targetLeft  = 0.0f;
    targetRight = 0.0f;
    cachedLeft  = 0.0f;
    cachedRight = 0.0f;
}

// ── BLE command parser ─────────────────────────────────────────────────────────

static void process_ble_text_line(const char *line)
{
    char reply[96];

    // // rawon / rawoff / raw — longer strings checked first to avoid prefix clash
    // if (strncmp(line, "rawon", 5) == 0) {
    //     raw_print_active = true;
    //     ble_send_line("OK raw printing on");

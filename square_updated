//RGB LED CLASS
class rgbLED {
private:
    DigitalOut red, green, blue;

public:
    rgbLED (PinName red_p, PinName green_p, PinName blue_p): red(red_p), green(green_p), blue(blue_p) {}

    void on() {
        red = 0;
        green = 0;
        blue = 0;
    }
    void off() {
        red = 1;
        green = 1;
        blue = 1;
    }
    void redOn() {
        red = 0;
        green = 1;
        blue = 1;
    }
    void greenOn() {
        red = 1;
        green = 0;
        blue = 1;
    }
    void blueOn() {
        red = 1;
        green = 1;
        blue = 0;
    }
};

